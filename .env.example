# RedevOps.io Social Autopilot - Environment Configuration
# Copy this file to .env and customize for your deployment

# ============================================
# LLM Provider Configuration
# ============================================

# Base URL for OpenAI-compatible API endpoint
# Options:
#   - OpenRouter: https://openrouter.ai/api/v1
#   - Ollama (local): http://host.docker.internal:11434/v1
#   - vLLM: http://your-vllm-server:8000/v1
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# API key for LLM provider (not needed for local Ollama without auth)
OPENAI_API_KEY=

# Model to use for content generation
# OpenRouter examples: mistralai/mistral-large-2407, anthropic/claude-3.5-sonnet
# Ollama examples: llama3.1:8b, mistral:nemo, qwen2.5:7b
MODEL=mistralai/mistral-large-2407

# ============================================
# Agent Configuration
# ============================================

# Logging level for agent services (DEBUG, INFO, WARNING, ERROR)
AGENT_LOG_LEVEL=INFO

# Maximum tokens for LLM responses
MAX_TOKENS=4096

# Temperature for content generation (0.0 = deterministic, 1.0 = creative)
TEMPERATURE=0.7

# ============================================
# Postiz Database Configuration
# ============================================

POSTGRES_USER=postiz
POSTGRES_PASSWORD=change-me-in-production-use-strong-password
POSTGRES_DB=postiz

# ============================================
# Security Configuration
# ============================================

# JWT secret for session management (generate with: openssl rand -hex 32)
JWT_SECRET=change-me-in-production-use-strong-secret

# API secret key for agent API authentication
API_SECRET_KEY=change-me-in-production-use-strong-secret

# ============================================
# Postiz Integration (optional, for advanced setup)
# ============================================

# Internal URL to Postiz backend (usually不需要 change in Docker Compose)
POSTIZ_API_URL=http://postiz-backend:3000

# API key for Postiz integration if required by your setup
POSTIZ_API_KEY=
